# =================================================================
# Large Data and Binary Files
# =================================================================
# Exclude large numpy/archive data files
*.npz
*.tar.bz2

# Exclude logs
*.log

# =================================================================
# PA-Specific Rules
# =================================================================

# --- PA 2: Test Directory ---
# Exclude all test files; re-include only essential scripts
PA_2/test/*
!PA_2/test/env_final_check.py
!PA_2/test/gen_charts.py

# --- PA 3: Paper Assets & Runtime Artifacts ---
# Exclude large paper/asset directory (MapTune resources)
PA_3/Materials/Paper/MapTune/
# ABC command history (generated in whichever dir abc is invoked)
PA_3/abc.history
abc.history

# =================================================================
# System, IDE, and Environment Artifacts
# =================================================================
# Python bytecode and cache
__pycache__/
*.pyc
*.pyo

# Local VS Code editor configurations (Path-dependent)
.vscode/

# =================================================================
# LaTeX Documentation & Compilation Artifacts
# =================================================================
# Exclude latexmk configuration and engine-generated helper files
*.latexmkrc
*.aux
*.fdb_latexmk
*.fls
*.out
*.synctex.gz
*.toc

# Exclude compiled PDFs (regenerated from .tex source)
main.pdf
